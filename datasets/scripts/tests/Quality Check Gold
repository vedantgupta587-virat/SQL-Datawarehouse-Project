SELECT DISTINCT
    ci.cst_gndr, 
    ca.gen,
    CASE WHEN ci.cst_gndr!='n/a' THEN ci.cst_gndr
    ELSE COALESCE(ca.gen, 'n/a')
    END AS new_gen
FROM silver_vk.crm_cust_info ci
LEFT JOIN silver_vk.erp_cust_az12 ca
    ON ci.cst_key = ca.cid
LEFT JOIN silver_vk.erp_loc_a101 la    -- Changed 'silver' to 'silver_vk' here
    ON ci.cst_key = la.cid 
ORDER BY 1,2 
