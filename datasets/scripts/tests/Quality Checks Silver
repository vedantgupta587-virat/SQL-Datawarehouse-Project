SELECT'Transformations in customer Table';
SELECT'Check For Nulls or Duplicates in Primary Key';
SELECT cst_id,COUNT(*)FROM bronze_vk.crm_cust_info GROUP BY cst_id HAVING COUNT(*)>1 OR cst_id IS NULL;
SELECT*FROM bronze_vk.crm_cust_info WHERE cst_id = 29466;
Select* FROM(SELECT*,ROW_NUMBER() OVER (PARTITION BY cst_id ORDER BY cst_create_date DESC) as flag_last FROM bronze_vk.crm_cust_info)t WHERE flag_last =1;

SELECT'Check For Unwanted Spaces';
SELECT cst_firstname FROM bronze_vk.crm_cust_info WHERE cst_firstname!= TRIM(cst_firstname);
SELECT cst_id,cst_key,TRIM(cst_firstname) AS cst_firstname,TRIM(cst_lastname) AS cst_lastname,cst_material_status,cst_gndr,cst_create_date FROM bronze_d.crm_cust_info ;

SELECT'Data Standardization and Consistency';
SELECT cst_id,cst_key,TRIM(cst_firstname) AS cst_firstname,TRIM(cst_lastname) AS cst_lastname,CASE WHEN UPPER(TRIM(cst_marital_status))='S' THEN 'Single' WHEN UPPER(TRIM(cst_marital_status))='M' THEN 'MARRIED' ELSE'n/a' END cst_marital_status,
CASE WHEN cst_gndr='F' THEN 'Female' When cst_gndr ='M' THEN'Male' ELSE'n/a' END cst_gndr,cst_create_date FROM bronze_vk.crm_cust_info ;

SELECT'Transformations in Product Table';

SELECT'Check For Nulls or Duplicates in Primary Key';
SELECT prd_id,COUNT(*)FROM bronze_vk.crm_prd_info GROUP BY prd_id HAVING COUNT(*)>1 OR prd_id IS NULL;
SELECT'Check For Unwanted Spaces';
SELECT prd_nm FROM bronze_d.crm_prd_info WHERE prd_nm!= TRIM(prd_nm);
SELECT prd_cost FROM bronze_d.crm_prd_info WHERE prd_cost<0 OR prd_cost IS NULL;
