SELECT'Truncate Table: silver_vk.crm_prd_info';
TRUNCATE TABLE silver_vk.crm_prd_info;
SELECT'Inserting Data into: silver_vk.crm_prd_info';
INSERT INTO silver_vk.crm_prd_info (
    prd_id,
    cat_id,
    prd_key,
    prd_nm,
    prd_cost,
    prd_line,
    prd_start_date,
    prd_end_date
)
SELECT
			prd_id,
			REPLACE(SUBSTRING(prd_key, 1, 5), '-', '_') AS cat_id, -- Extract category ID
			SUBSTRING(prd_key, 7, 12) AS prd_key,        -- Extract product key
			prd_nm,
			IFNULL(prd_cost, 0) AS prd_cost,
			CASE 
				WHEN UPPER(TRIM(prd_line)) = 'M' THEN 'Mountain'
				WHEN UPPER(TRIM(prd_line)) = 'R' THEN 'Road'
				WHEN UPPER(TRIM(prd_line)) = 'S' THEN 'Other Sales'
				WHEN UPPER(TRIM(prd_line)) = 'T' THEN 'Touring'
				ELSE 'n/a'
			END AS prd_line, -- Map product line codes to descriptive values
			CAST(prd_start_date AS DATE) AS prd_start_date,
			CAST(DATE_SUB(LEAD(prd_start_date) OVER (PARTITION BY prd_key ORDER BY prd_start_date), INTERVAL 1 DAY) AS DATE) AS prd_end_date
		FROM bronze_vk.crm_prd_info;
        SELECT*FROM silver_vk.crm_prd_info;

SELECT'Truncate Table: silver_vk.crm_sales_details';
TRUNCATE TABLE silver_vk.crm_sales_details;
SELECT'Inserting Data into: silver_vk.crm_sales_details';
INSERT INTO silver_vk.crm_sales_details (
    sls_ord_num,
    sls_prd_key,
    sls_cust_id,
    sls_order_dt,
    sls_ship_dt,
    sls_due_dt,
    sls_sales,
    sls_quantity,
    sls_price
)    
SELECT 
    sls_ord_num,
    sls_prd_key,
    sls_cust_id,
    
    -- Clean Dates
    CASE 
        WHEN sls_order_dt = 0 OR LENGTH(sls_order_dt) != 8 THEN NULL
        ELSE STR_TO_DATE(CAST(sls_order_dt AS CHAR), '%Y%m%d')
    END AS sls_order_dt, 
    
    CASE 
        WHEN sls_ship_dt = 0 OR LENGTH(sls_ship_dt) != 8 THEN NULL
        ELSE STR_TO_DATE(CAST(sls_ship_dt AS CHAR), '%Y%m%d')
    END AS sls_ship_dt, 
    
    CASE 
        WHEN sls_due_dt = 0 OR LENGTH(sls_due_dt) != 8 THEN NULL
        ELSE STR_TO_DATE(CAST(sls_due_dt AS CHAR), '%Y%m%d')
    END AS sls_due_dt, 
    
    -- Clean Sales & Prices
    CASE 
         WHEN sls_sales IS NULL OR sls_sales <= 0 OR sls_sales != sls_quantity * ABS(sls_price)
         THEN sls_quantity * ABS(sls_price)
         ELSE sls_sales
    END AS sls_sales,
    
    sls_quantity,
    
    CASE 
         WHEN sls_price IS NULL OR sls_price <= 0
         THEN sls_sales / NULLIF(sls_quantity, 0)
         ELSE sls_price
    END AS sls_price

FROM bronze_vk.crm_sales_details;
SELECT*FROM silver_vk.crm_sales_details;

SELECT'Truncate Table: silver_vk.erp_cust_az12';
TRUNCATE TABLE silver_vk.erp_cust_az12;
SELECT'Inserting Data into:silver_vk.erp_cust_az12';
INSERT INTO silver_vk.erp_cust_az12 (cid,bdate,gen)
SELECT 
    CASE 
        WHEN cid LIKE 'NAS%' THEN SUBSTRING(cid, 4, LENGTH(cid))
        ELSE cid
    END AS cid,
    CASE WHEN bdate> CURRENT_DATE THEN null
         ELSE bdate
	END AS bdate,
    CASE WHEN UPPER(TRIM(gen)) IN ('F','FEMALE') THEN 'Female'
     WHEN UPPER(TRIM(gen)) IN ('M','MALE') THEN 'Male'
     ELSE 'n/a'
END AS gen
FROM bronze_vk.erp_cust_az12;
SELECT*FROM silver_vk.erp_cust_az12;

